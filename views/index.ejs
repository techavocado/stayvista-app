<% layout("layouts/boilerplate") %>

    <div class="filters-main-container position-relative">

        <div class="filter-carousel-wrapper">
            <button class="scroll-btn" id="scrollLeftBtn">
                <i class="fa-solid fa-chevron-left"></i>
            </button>

            <div style="overflow: hidden; width: 100%; max-width: 600px;">
                <div id="filters-track">
                    <div class="filter"><i class="fa-solid fa-fire"></i>
                        <p>Trending</p>
                    </div>
                    <div class="filter"><i class="fa-solid fa-bed"></i>
                        <p>Rooms</p>
                    </div>
                    <div class="filter"><i class="fa-solid fa-mountain-city"></i>
                        <p>Cities</p>
                    </div>
                    <div class="filter"><i class="fa-solid fa-mountain"></i>
                        <p>Mountains</p>
                    </div>
                    <div class="filter"><i class="fa-brands fa-fort-awesome"></i>
                        <p>Castles</p>
                    </div>
                    <div class="filter"><i class="fa-solid fa-person-swimming"></i>
                        <p>Pools</p>
                    </div>
                </div>
            </div>

            <button class="scroll-btn" id="scrollRightBtn">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>

        <div class="tax-toggle">
            <label class="toggle-label" for="flexSwitchCheckDefault">Display total after taxes</label>

            <div class="form-check form-switch m-0">
                <input class="form-check-input toggle-switch-btn" type="checkbox" role="switch"
                    id="flexSwitchCheckDefault">
            </div>
        </div>

    </div>

    <div class="listwaladiv">

        <!-- <h1 class="heading">All Listings</h1> -->

        <div class="container">


            <div class="listings-container">
                <% for(let item of data){ %>

                    <a href="/listings/<%= item._id %>/show" class="card-link">
                        <div class="listing-card">

                            <div class="image-wrapper">
                                <img src="<%= item.image.url %>" class="listing-img">

                                <!-- Heart Icon -->
                                <div class="heart">♡</div>
                            </div>

                            <div class="listing-info">
                                <h3>
                                    <%= item.title %>
                                </h3>

                                <p class="price">
                                    <span class="base-price">
                                        ₹<%= item.price.toLocaleString("en-IN") %> / night
                                    </span>

                                    <span class="total-price" style="display: none;">
                                        ₹<%= Math.round(item.price * 1.18).toLocaleString("en-IN") %> total
                                    </span>

                                    <i class="tax-info" style="display: none; color: gray; font-size: 0.9rem;">
                                        &nbsp; (incl. 18% GST)
                                    </i>
                                </p>
                            </div>


                        </div>



                        <% } %>
            </div>



        </div>

        <script>
            const track = document.getElementById('filters-track');
            const leftBtn = document.getElementById('scrollLeftBtn');
            const rightBtn = document.getElementById('scrollRightBtn');

            // Filter ki width + gap calculate karna (approx 120px)
            const moveDistance = 120;

            // Jab Right dabayein: Pehla item uthakar aakhri mein daal do (Circle forward)
            rightBtn.addEventListener('click', () => {
                track.style.transition = "transform 0.3s ease-in-out";
                track.style.transform = `translateX(-${moveDistance}px)`;

                setTimeout(() => {
                    track.style.transition = "none";
                    track.appendChild(track.firstElementChild); // Pehle ko last mein bhejo
                    track.style.transform = "translateX(0)";
                }, 300); // 300ms transition time ke barabar
            });

            // Jab Left dabayein: Aakhri item uthakar pehle par le aao (Circle backward)
            leftBtn.addEventListener('click', () => {
                track.style.transition = "none";
                track.prepend(track.lastElementChild); // Last ko first mein bhejo
                track.style.transform = `translateX(-${moveDistance}px)`;

                // Thoda delay dekar smooth wapas laao
                setTimeout(() => {
                    track.style.transition = "transform 0.3s ease-in-out";
                    track.style.transform = "translateX(0)";
                }, 10);
            });

            // ==========================================
            // MOBILE FINGER SWIPE (TOUCH) FUNCTIONALITY
            // ==========================================
            let startX = 0;
            let endX = 0;

            // Jab finger screen par touch ho
            track.addEventListener('touchstart', (e) => {
                startX = e.changedTouches[0].screenX;
            }, { passive: true });

            // Jab finger screen se hate
            track.addEventListener('touchend', (e) => {
                endX = e.changedTouches[0].screenX;
                handleSwipe();
            }, { passive: true });

            // Swipe ki direction check karke button click trigger karna
            function handleSwipe() {
                const swipeThreshold = 40; // Kam se kam kitna lamba swipe hona chahiye

                if (startX - endX > swipeThreshold) {
                    // Finger ne Left swipe kiya -> Right wale items dikhao
                    rightBtn.click();
                }
                else if (endX - startX > swipeThreshold) {
                    // Finger ne Right swipe kiya -> Left wale items dikhao
                    leftBtn.click();
                }
            }

            // ==========================================
            // LAPTOP TRACKPAD 2-FINGER SWIPE (WHEEL EVENT)
            // ==========================================
            let isTrackpadScrolling = false;

            track.addEventListener('wheel', (e) => {
                // Check karo ki user Left/Right swipe kar raha hai ya Up/Down
                if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) {
                    e.preventDefault(); // Page ko horizontal hilne se roko

                    // Agar pehle se scroll nahi chal raha, tabhi aage badho
                    if (!isTrackpadScrolling) {
                        if (e.deltaX > 0) {
                            rightBtn.click(); // 2-finger Right Swipe
                        } else if (e.deltaX < 0) {
                            leftBtn.click();  // 2-finger Left Swipe
                        }

                        // COOLDOWN: Trackpad ek second mein 100 events bhejta hai.
                        // Agar hum cooldown nahi lagayenge toh list slot-machine ki tarah ghumegi!
                        isTrackpadScrolling = true;
                        setTimeout(() => {
                            isTrackpadScrolling = false;
                        }, 400); // 400ms ka delay (Animation time ke barabar)
                    }
                }
            }, { passive: false });


            // ==========================================
    // TAX TOGGLE SWITCH (Airbnb Style)
    // ==========================================
    
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");
    
    // Teeno elements ki list nikal lo
    let basePrices = document.querySelectorAll(".base-price");
    let totalPrices = document.querySelectorAll(".total-price");
    let taxInfos = document.querySelectorAll(".tax-info");

    taxSwitch.addEventListener("change", () => {
        // Har listing card par loop chalayenge
        for (let i = 0; i < basePrices.length; i++) {
            
            if (taxSwitch.checked) {
                // Agar ON hai: Base chhupao, Total aur Info dikhao
                basePrices[i].style.display = "none";
                totalPrices[i].style.display = "inline";
                taxInfos[i].style.display = "inline";
            } else {
                // Agar OFF hai: Base dikhao, Total aur Info chhupao
                basePrices[i].style.display = "inline";
                totalPrices[i].style.display = "none";
                taxInfos[i].style.display = "none";
            }
            
        }
    });
        </script>