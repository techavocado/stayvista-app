
<!-- if success exist and its legth is equal ot zero then the following code executes -->
<% if(success && success.length> 0){ %>
            <div class="container mt-3 col-6 offset-3">
                <div class="alert alert-success alert-dismissible fade show text-center shadow-sm" role="alert">
                    <strong>Success!</strong>
                    <%= success%>

                        <!-- data-bs-dismiss used to cut the msg and remove it -->
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
            <% } %>


<% if(error && error.length > 0){ %>
    <div class="container mt-3 col-6 offset-3">
                <div class="alert alert-danger alert-dismissible fade show text-center shadow-sm" role="alert">
                    <strong>Error!</strong>
                    <%= error%>

                        <!-- data-bs-dismiss used to cut the msg and remove it -->
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
<% } %>

            