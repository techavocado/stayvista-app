<!-- CHANGED: outer <header> wrapper — zero visual impact on desktop -->
<header class="sticky-top" style="z-index: 999;">

    <nav class="custom-nav px-3 px-md-4 py-3 border-bottom bg-white d-flex align-items-center justify-content-between">

        <a href="/listings" class="logo d-flex align-items-center gap-2 text-decoration-none flex-shrink-0">
            <img class="meralogo" src="/images/logo5.png" alt="logo" style="height: 32px;">
            <span class="brand-name fs-4 fw-bold text-danger">StayVista</span>
        </a>

        <div class="search-bar-desktop d-none d-md-block position-absolute start-50 translate-middle-x">
            <form action="/listings" method="GET" class="d-inline-flex align-items-center border rounded-pill shadow-sm p-1 bg-white m-0" style="transition: box-shadow 0.2s;">
                <span class="px-3 fw-semibold text-dark d-none d-lg-block" style="font-size: 0.85rem;">Anywhere</span>
                <div class="vr d-none d-lg-block"></div>
                <span class="px-3 fw-semibold text-dark d-none d-lg-block" style="font-size: 0.85rem;">Any week</span>
                <div class="vr d-none d-lg-block"></div>
                <input name="searchtitle" type="text" class="border-0 bg-transparent px-3 text-dark"
                    placeholder="Search destinations"
                    style="font-size: 0.85rem; outline: none; box-shadow: none; max-width: 130px;">
                <button type="submit"
                    class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center ms-2 border-0"
                    style="width: 32px; height: 32px; cursor: pointer;">
                    <i class="fa-solid fa-magnifying-glass" style="font-size: 0.8rem;"></i>
                </button>
            </form>
        </div>

        <div class="nav-links d-flex align-items-center gap-2 gap-md-3">

            <a href="/listings" class="btn-glass nav-glass-btn text-decoration-none text-dark fw-medium px-2 py-1" style="font-size: 0.85rem;">
                <i class="fa-solid fa-house d-md-none"></i>
                <span class="d-none d-md-inline">Home</span>
            </a>

            <a href="/create" class="btn-glass nav-glass-btn text-decoration-none text-dark fw-medium px-2 py-1" style="font-size: 0.85rem;">
                <i class="fa-solid fa-plus d-md-none"></i>
                <span class="d-none d-md-inline">Add Listing</span>
            </a>

            <div class="d-flex align-items-center gap-1 gap-md-2 ms-1">
                <% if(!currUser){ %>
                    <a href="/login" class="btn-glass nav-glass-btn text-decoration-none text-dark fw-medium px-2 py-1"
                        style="font-size: 0.85rem;">Log In</a>
                    <a href="/signup" class="btn-glass nav-glass-btn text-decoration-none text-dark fw-medium px-2 py-1 d-none d-sm-block"
                        style="font-size: 0.85rem;">Sign Up</a>
                <% } %>

                <% if(currUser){ %>
                    <a href="/logout" class="btn-glass nav-glass-btn text-decoration-none text-dark fw-medium px-2 py-1"
                        style="font-size: 0.85rem;">Logout</a>
                    <a href="/profile" class="ms-1">
                        <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png"
                            class="rounded-circle border shadow-sm"
                            style="width: 28px; height: 28px; object-fit: cover;" alt="Profile">
                    </a>
                <% } %>
            </div>
        </div>
    </nav>

 
    <div class="search-bar-wrapper d-md-none bg-white">
        <form action="/listings" method="GET" class="d-inline-flex align-items-center border rounded-pill shadow-sm p-1 bg-white m-0">
            <input name="searchtitle" type="text" class="border-0 bg-transparent px-3 text-dark"
                placeholder="Search destinations..."
                style="font-size: 0.85rem; outline: none; box-shadow: none;">
            <button type="submit"
                class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center ms-1 border-0"
                style="width: 32px; height: 32px; cursor: pointer; flex-shrink: 0;">
                <i class="fa-solid fa-magnifying-glass" style="font-size: 0.8rem;"></i>
            </button>
        </form>
    </div>

</header>
