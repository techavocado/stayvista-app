<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logout</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">

    <div class="card shadow-lg p-5 rounded-4 text-center" style="max-width: 600px; width: 100%;">

        <h2 class="mb-3 fw-bold">Logout</h2>

        <p class="text-muted mb-2 fs-5">You are logged in as</p>

        <h4 class="fw-semibold"><%= username %></h4>
        <p class="text-muted mb-4 fs-6"><%= email %></p>

        <p class="text-danger mb-4 fs-5">Are you sure you want to logout?</p>

        <form method="POST" action="/logout">
            <button type="submit" class="btn btn-danger w-100 py-2 fs-5 mb-3">
                Logout
            </button>
        </form>

        <a href="/listings" class="btn btn-outline-secondary w-100 py-2 fs-5">
            Cancel
        </a>

    </div>

</body>
</html>